# Business-in-a-Box package (server-side)
#
# These values come from Site Builder → Developer → Package API & Unkey keys.
# Copy this file to `.env.local` (never commit it). On Vercel, set the same
# three values as Environment Variables on the Production / Preview scopes.
#
# When you want to run the demo against a locally running host, point the base
# URL at http://localhost:3000/api/package/v1 and leave the production values
# in the Vercel dashboard only.

BIAB_API_KEY=biab_YourKeyFromSiteBuilderDevPanel
BIAB_SITE_ID=00000000-0000-0000-0000-000000000000
BIAB_PACKAGE_API_BASE_URL=https://your-host.example.com/api/package/v1

# Optional: if your generated client reads a public base URL
# NEXT_PUBLIC_BIAB_PACKAGE_API_BASE_URL=
